<Window x:Class="BimTasksV2.Views.FloatingToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        MinWidth="130"
        MinHeight="80"
        Width="480"
        Height="220"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Header control button -->
        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#28000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group header button -->
        <Style x:Key="GroupHeaderBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0A000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#12000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsVertical, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Outer border with drop shadow (margin provides space for shadow rendering) -->
    <Border CornerRadius="6" Background="#F0F2F5" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.22" ShadowDepth="2" Color="#333333"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar / drag handle -->
            <Border Grid.Row="0" Background="#E4E7EB" CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2807;" FontSize="14" Foreground="#999" Margin="0,0,5,0"
                                   FontFamily="Segoe UI Symbol"/>
                        <TextBlock Text="BimTasks" FontWeight="SemiBold" FontSize="11.5" Foreground="#444"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource HeaderBtn}"
                                Command="{Binding ToggleOrientationCommand}"
                                ToolTip="Toggle horizontal / vertical layout">
                            <TextBlock Text="{Binding OrientationIcon}" FontSize="12" Foreground="#666"/>
                        </Button>
                        <Button Style="{StaticResource HeaderBtn}" Click="Close_Click"
                                ToolTip="Hide toolbar">
                            <TextBlock Text="&#x2715;" FontSize="10" Foreground="#666"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area -->
            <ScrollViewer Grid.Row="1" Padding="3"
                          HorizontalScrollBarVisibility="{Binding HScrollVisibility}"
                          VerticalScrollBarVisibility="{Binding VScrollVisibility}">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="{Binding DataContext.GroupsOrientation,
                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="2">
                                <!-- Group header: accent bar + chevron + name -->
                                <Button Style="{StaticResource GroupHeaderBtn}"
                                        Command="{Binding DataContext.ToggleGroupCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="2"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Rectangle Grid.Row="0" Fill="{Binding AccentBrush}"
                                                   RadiusX="1" RadiusY="1"/>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding ExpanderIcon}" FontSize="8"
                                                       Foreground="#888" VerticalAlignment="Center"
                                                       Margin="0,0,3,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="#777"
                                                       FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <!-- Buttons (visible when group is expanded) -->
                                <ItemsControl ItemsSource="{Binding Buttons}"
                                              Visibility="{Binding IsExpanded,
                                                           Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="{Binding DataContext.ButtonsOrientation,
                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ToolbarBtn}"
                                                    Command="{Binding DataContext.ExecuteCommandCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}">
                                                <Button.ToolTip>
                                                    <ToolTip MaxWidth="260">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                                       FontSize="12" Foreground="#222"/>
                                                            <TextBlock Text="{Binding Tooltip}" FontSize="11"
                                                                       Foreground="#555" TextWrapping="Wrap"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Button.ToolTip>
                                                <StackPanel Orientation="Horizontal">
                                                    <Image x:Name="iconImg" Source="{Binding Icon}"
                                                           Width="20" Height="20" Margin="0,0,4,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="10.5"
                                                               VerticalAlignment="Center" Foreground="#333"/>
                                                </StackPanel>
                                            </Button>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                    <Setter TargetName="iconImg" Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Resize grip indicator (bottom-right corner) -->
            <Canvas Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="12" Height="12" Margin="0,0,2,2" IsHitTestVisible="False">
                <Line X1="11" Y1="3" X2="3" Y2="11" Stroke="#CCC" StrokeThickness="1"/>
                <Line X1="11" Y1="6" X2="6" Y2="11" Stroke="#CCC" StrokeThickness="1"/>
                <Line X1="11" Y1="9" X2="9" Y2="11" Stroke="#CCC" StrokeThickness="1"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
