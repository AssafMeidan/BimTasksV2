<Window x:Class="BimTasksV2.Views.OverlappingWallsResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlapping Walls Detected"
        MinWidth="550" MinHeight="380"
        Width="620" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Summary -->
        <TextBlock Grid.Row="0"
                   Text="{Binding SummaryText}"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Results DataGrid -->
        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Groups}"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="35"/>
                <DataGridTextColumn Header="Wall Type" Binding="{Binding TypeName}" Width="*"/>
                <DataGridTextColumn Header="Count" Binding="{Binding WallCount}" Width="55"/>
                <DataGridTextColumn Header="Wall IDs" Binding="{Binding WallIds}" Width="180"/>
                <DataGridTextColumn Header="Overlap (m)" Binding="{Binding OverlapMeters}" Width="85"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action selection -->
        <GroupBox Grid.Row="2" Header="Action" Margin="0,0,0,8" Padding="8,6">
            <StackPanel>
                <RadioButton x:Name="RbHighlight" Content="Highlight — Isolate overlapping walls in view"
                             GroupName="Action" IsChecked="True" Margin="0,2"/>
                <RadioButton x:Name="RbUnjoin" Content="Unjoin — Separate geometry so duplicates become visible"
                             GroupName="Action" Margin="0,2"/>
                <RadioButton x:Name="RbDelete" Content="Delete duplicates — Keep oldest wall, delete the rest"
                             GroupName="Action" Margin="0,2"/>
            </StackPanel>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Apply" Width="90" Height="30" Margin="0,0,8,0"
                    Click="ApplyButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="90" Height="30"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
