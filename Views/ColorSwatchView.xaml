<UserControl x:Class="BimTasksV2.Views.ColorSwatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="350"
             Background="#FAFAFA">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Parameter dropdown -->
        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="Parameter:" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
            <ComboBox ItemsSource="{Binding ParameterNames}"
                      SelectedItem="{Binding SelectedParameter}"
                      FontSize="12"/>
        </StackPanel>

        <!-- Description parameter dropdown -->
        <StackPanel Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="Show with:" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
            <ComboBox ItemsSource="{Binding DescriptionParameterNames}"
                      SelectedItem="{Binding SelectedDescriptionParameter}"
                      FontSize="12"/>
        </StackPanel>

        <!-- Category multi-select -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="Categories:" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
            <ToggleButton x:Name="CategoryToggle"
                          Content="{Binding CategorySummary}"
                          IsChecked="{Binding IsCategoryDropdownOpen}"
                          HorizontalContentAlignment="Left"
                          Padding="6,4" FontSize="12"
                          BorderBrush="#CCCCCC" BorderThickness="1"
                          Background="White"/>
            <Popup IsOpen="{Binding IsCategoryDropdownOpen}"
                   PlacementTarget="{Binding ElementName=CategoryToggle}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                        MaxHeight="250" MinWidth="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}"
                                              Margin="2,1" FontSize="11">
                                        <CheckBox.Content>
                                            <TextBlock>
                                                <Run Text="{Binding Name}"/>
                                                <Run Text=" (" Foreground="#999"/>
                                                <Run Text="{Binding Count}" Foreground="#999"/>
                                                <Run Text=")" Foreground="#999"/>
                                            </TextBlock>
                                        </CheckBox.Content>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>
        </StackPanel>

        <!-- Apply / Refresh / Clear buttons -->
        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Apply Colors"
                        Command="{Binding ApplyColorsCommand}"
                        Height="28" FontSize="12"/>
                <Button Grid.Column="2" Content="&#x21BB;"
                        Command="{Binding RefreshCommand}"
                        Height="28" Width="28" FontSize="14"
                        ToolTip="Refresh — re-scan elements, keep colors"
                        FontFamily="Segoe UI Symbol"/>
                <Button Grid.Column="4" Content="Clear Colors"
                        Command="{Binding ClearColorsCommand}"
                        Height="28" FontSize="12"/>
            </Grid>
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Create Legend"
                        Command="{Binding CreateLegendCommand}"
                        Height="28" FontSize="11"
                        ToolTip="Create a drafting view legend from the current swatch"/>
                <Button Grid.Column="2" Content="Reset View Overrides"
                        Command="{Binding ResetViewCommand}"
                        Height="28" FontSize="11"
                        ToolTip="Remove all color swatch overrides from the active view"
                        Foreground="#B71C1C"/>
            </Grid>
        </StackPanel>

        <!-- Swatch legend list -->
        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="2">
            <ListView ItemsSource="{Binding SwatchRows}"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      SelectionChanged="SwatchList_SelectionChanged"
                      x:Name="SwatchList">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="ToolTip" Value="Click to select elements"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Clickable color swatch -->
                            <Border Grid.Column="0" Width="18" Height="18"
                                    CornerRadius="2" Cursor="Hand"
                                    BorderBrush="#999" BorderThickness="1"
                                    Background="{Binding ColorBrush}"
                                    PreviewMouseLeftButtonDown="Swatch_Click"
                                    ToolTip="Click to change color"/>

                            <!-- Value text -->
                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                       VerticalAlignment="Center" Margin="6,0,4,0"
                                       FontSize="11" TextTrimming="CharacterEllipsis"/>

                            <!-- Description text -->
                            <TextBlock Grid.Column="2" Text="{Binding Description}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       FontSize="10" Foreground="#777"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="100"/>

                            <!-- Count -->
                            <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                       FontSize="10" Foreground="#999" Margin="0,0,4,0">
                                <Run Text="("/>
                                <Run Text="{Binding Count, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</UserControl>
