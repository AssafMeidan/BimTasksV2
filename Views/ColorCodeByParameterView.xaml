<UserControl x:Class="BimTasksV2.Views.ColorCodeByParameterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#F5F5F5">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1976D2"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212121"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#757575"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResetButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#757575"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#616161"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controls Section -->
        <StackPanel Grid.Row="0">

            <!-- Settings Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Color Code by Parameter" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>

                    <!-- Primary Parameter -->
                    <TextBlock Text="Primary Parameter" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ParameterNames}"
                              SelectedItem="{Binding SelectedPrimaryParam}"
                              IsEditable="True" Height="28" FontSize="12" Margin="0,0,0,10"/>

                    <!-- Secondary Parameter -->
                    <TextBlock Text="Secondary Parameter (optional)" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ParameterNames}"
                              SelectedItem="{Binding SelectedSecondaryParam}"
                              IsEditable="True" Height="28" FontSize="12" Margin="0,0,0,10"/>

                    <!-- Scope -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="Selected Elements" IsChecked="{Binding UseSelection}"
                                     FontSize="12" Margin="0,0,16,0"/>
                        <RadioButton Content="All in View" FontSize="12"
                                     IsChecked="{Binding UseAllInView}"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Apply Colors" Command="{Binding ApplyCommand}"
                                Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}"
                                Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                        <Button Content="Shuffle" Command="{Binding ShuffleColorsCommand}"
                                Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                        <Button Content="Reset" Command="{Binding ResetCommand}"
                                Style="{StaticResource ResetButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status -->
            <TextBlock Text="{Binding StatusText}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="2,0,0,8"/>
        </StackPanel>

        <!-- Legend List -->
        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="4">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270"/>
            </Border.Effect>
            <ListView ItemsSource="{Binding LegendItems}"
                      SelectedItem="{Binding SelectedLegendItem}"
                      BorderThickness="0" Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,3" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Color Swatch (clickable to change color) -->
                            <Button Grid.Column="0" Click="SwatchButton_Click"
                                    Cursor="Hand" ToolTip="Click to change color">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Rectangle Width="14" Height="14"
                                                   RadiusX="3" RadiusY="3"
                                                   Stroke="#E0E0E0" StrokeThickness="0.5">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="{Binding SwatchColor}"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Values -->
                            <StackPanel Grid.Column="1" Margin="6,0,4,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryValue}" FontSize="12"
                                           FontWeight="Medium" Foreground="#212121"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SecondaryValue}" FontSize="11"
                                           Foreground="#757575"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding SecondaryVisibility}"/>
                            </StackPanel>

                            <!-- Count -->
                            <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                       FontSize="11" Foreground="#9E9E9E"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="2"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Border>

        <!-- Color Picker Popup -->
        <Popup x:Name="ColorPickerPopup" StaysOpen="False"
               AllowsTransparency="True" PopupAnimation="Fade"
               Placement="Right">
            <Border Background="White" BorderBrush="#E0E0E0"
                    BorderThickness="1" CornerRadius="6" Padding="6">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                </Border.Effect>
                <ItemsControl ItemsSource="{Binding PaletteColors}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Width="168"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="24" Height="24" Margin="2"
                                    Cursor="Hand" Click="PaletteColor_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="3"
                                                BorderBrush="#CCC" BorderThickness="0.5">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding}"/>
                                            </Border.Background>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#333"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>
    </Grid>
</UserControl>
